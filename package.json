{
  "name": "finance-dashboard",
  "version": "1.0.0",
  "type": "module",
  "description": "Personal Finance Dashboard with AI Advisor",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\" --names \"API,UI\" --prefix-colors \"cyan,magenta\"",
    "server": "node server/index.js",
    "client": "npm --prefix client run dev",
    "install:all": "npm install && npm --prefix client install",
    "test:ui": "playwright test"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^8.2.2"
  }
}
